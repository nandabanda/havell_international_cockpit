def normalize_hunting_approvals(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return df
    d = df.copy()
    d["module"] = "HUNTING"
    d["source"] = "hunting_approval_queue"

    entity = pick(d, ["account","project","partner","customer","opportunity","entity","name","title"])
    d["entity"] = d[entity].astype(str) if entity else "Hunting item"

    d["exception_type"] = "Approval Required"
    sev = pick(d, ["severity","risk_band","priority"])
    d["severity"] = d[sev].astype(str) if sev else "MEDIUM"

    conf = pick(d, ["confidence","conf"])
    d["confidence"] = d[conf].astype(str) if conf else "MEDIUM"

    status = pick(d, ["status","state"])
    d["status"] = d[status].astype(str) if status else "PENDING"

    owner = pick(d, ["owner","approver","function"])
    d["owner"] = d[owner].astype(str) if owner else "Commercial"

    why = pick(d, ["notes","comment","reason","narrative"])
    d["recommended_action"] = d[why].astype(str) if why else "Review & approve"

    # value at risk proxy (best effort)
    var = pick(d, ["value_at_risk","value_risk_cr","impact_cr","impact","var"])
    d["value_at_risk"] = d[var] if var else 0.0

    ts = pick(d, ["ts","created_at","updated_at","week_id"])
    d["ts"] = d[ts] if ts else ""

    return d[["module","source","entity","exception_type","severity","confidence","status","owner","recommended_action","value_at_risk","ts"]]

def normalize_forward_signal(df: pd.DataFrame) -> pd.DataFrame:
    """Hunting forward signals are NOT approvals; they are 'risk signals' that should rank below PENDING approvals unless severe."""
    if df.empty:
        return df
    d = df.copy()
    d["module"] = "HUNTING"
    d["source"] = "hunting_forward_signal"

    entity = pick(d, ["account","project","partner","customer","entity","name","opportunity","title"])
    d["entity"] = d[entity].astype(str) if entity else "Hunting signal"

    d["exception_type"] = "Forward Risk Signal"
    sev = pick(d, ["severity","risk_band","risk_level","signal_band"])
    d["severity"] = d[sev].astype(str) if sev else "MEDIUM"

    conf = pick(d, ["confidence","conf"])
    d["confidence"] = d[conf].astype(str) if conf else "MEDIUM"

    d["status"] = "OPEN"
    owner = pick(d, ["owner","function"])
    d["owner"] = d[owner].astype(str) if owner else "Commercial"

    why = pick(d, ["narrative","reason","driver","explain"])
    d["recommended_action"] = d[why].astype(str) if why else "Investigate; prevent slippage"

    var = pick(d, ["value_at_risk","impact_cr","impact","var"])
    d["value_at_risk"] = d[var] if var else 0.0

    ts = pick(d, ["ts","created_at","updated_at","week_id"])
    d["ts"] = d[ts] if ts else ""

    return d[["module","source","entity","exception_type","severity","confidence","status","owner","recommended_action","value_at_risk","ts"]]

def normalize_supply_stress(df: pd.DataFrame, level: str) -> pd.DataFrame:
    if df.empty:
        return df
    d = df.copy()
    d["module"] = "SUPPLY"
    d["source"] = f"supply_stress_{level.lower()}"

    sku = pick(d, ["sku","sku_id","material","item","product"])
    plant = pick(d, ["plant","site","factory"])
    key = sku or plant

    d["entity"] = d[key].astype(str) if key else f"Supply stress ({level})"

    d["exception_type"] = f"Supply Stress ({level})"
    sev = pick(d, ["severity","risk_band","stress_band","stress_level"])
    d["severity"] = d[sev].astype(str) if sev else "MEDIUM"

    conf = pick(d, ["confidence","conf"])
    d["confidence"] = d[conf].astype(str) if conf else "MEDIUM"

    d["status"] = "OPEN"
    d["owner"] = "Supply"

    why = pick(d, ["reason","driver","root_cause"])
    d["recommended_action"] = d[why].astype(str) if why else "Assign resolution action"

    var = pick(d, ["value_at_risk","impact_cr","impact","var","revenue_at_risk"])
    d["value_at_risk"] = d[var] if var else 0.0

    ts = pick(d, ["ts","created_at","updated_at","week_id"])
    d["ts"] = d[ts] if ts else ""

    return d[["module","source","entity","exception_type","severity","confidence","status","owner","recommended_action","value_at_risk","ts"]]

