def apply_filters(df: pd.DataFrame) -> pd.DataFrame:
    d = df.copy()
    if d.empty:
        return d
    if mod != "ALL":
        d = d[d["module"].astype(str).str.upper().eq(mod)]
    if sev != "ALL":
        d = d[d["severity"].astype(str).str.upper().eq(sev)]
    if stat != "ALL":
        d = d[d["status"].astype(str).str.upper().eq(stat)]
    return d

