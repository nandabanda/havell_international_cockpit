def now_ts():
    return datetime.now().isoformat(timespec="seconds")

def safe_csv(fp: Path) -> pd.DataFrame:
    try:
        return pd.read_csv(fp)
    except Exception:
        return pd.DataFrame()

def safe_json(fp: Path) -> dict:
    try:
        return json.loads(fp.read_text(encoding="utf-8"))
    except Exception:
        return {}

def append_csv(path: Path, rec: dict):
    df = pd.DataFrame([rec])
    if path.exists():
        old = pd.read_csv(path)
        out = pd.concat([old, df], ignore_index=True)
    else:
        out = df
    out.to_csv(path, index=False)

def arrow_safe(df: pd.DataFrame) -> pd.DataFrame:
    """Arrow-safe rendering: coerces mixed-type numeric columns (e.g., qty with '')."""
    if df is None or not hasattr(df, "columns") or getattr(df, "empty", False):
        return df
    d = df.copy()
    for c in d.columns:
        cl = str(c).lower()
        if any(k in cl for k in [
            "qty","quantity","units","cases",
            "value","sales","revenue","impact","risk","var",
            "doh","days","fill","otif","service",
            "score","severity","confidence",
            "short","gap","stock","inv","cost","margin",
            "priority","eta","week"
        ]):
            d[c] = pd.to_numeric(d[c].astype(str).replace({"": None, "nan": None, "None": None}), errors="coerce")
    return d

def pick(df: pd.DataFrame, cols):
    for c in cols:
        if c in df.columns:
            return c
    return None

def norm_upper(x):
    return str(x).strip().upper() if x is not None else ""

