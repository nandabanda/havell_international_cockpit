# ------------------------------------------------------------
# Executive Ordering Logic (Decision Engine)
# ------------------------------------------------------------
SEV_MAP = {"CRITICAL": 400, "HIGH": 300, "MEDIUM": 200, "LOW": 100}
CONF_MAP = {"HIGH": 30, "MEDIUM": 20, "LOW": 10}
STATUS_MAP = {
    "PENDING": 60, "OPEN": 50, "IN_PROGRESS": 40, "WATCHLIST": 30,
    "CLOSED": 10, "APPROVED": 5, "REJECTED": 5
}
MOD_MAP = {"HUNTING": 2, "SUPPLY": 1}

if not unified.empty:
    unified["severity_n"] = unified["severity"].map(lambda x: SEV_MAP.get(norm_upper(x), 0))
    unified["confidence_n"] = unified["confidence"].map(lambda x: CONF_MAP.get(norm_upper(x), 0))
    unified["status_n"] = unified["status"].map(lambda x: STATUS_MAP.get(norm_upper(x), 0))
    unified["module_n"] = unified["module"].map(lambda x: MOD_MAP.get(norm_upper(x), 0))

    unified["value_at_risk"] = pd.to_numeric(
        unified["value_at_risk"].astype(str).replace({"": None, "nan": None, "None": None}),
        errors="coerce"
    ).fillna(0.0)

    # recency best-effort
    unified["ts_n"] = pd.to_numeric(unified["ts"], errors="coerce").fillna(0)

    # Composite decision score (transparent)
    # status carries meeting urgency, then severity, then confidence, then VAR
    unified["decision_score"] = (
        unified["status_n"]
        + unified["severity_n"] / 10.0
        + unified["confidence_n"]
        + np.log1p(unified["value_at_risk"].clip(lower=0)) * 5.0
        + unified["module_n"]
    )

    unified = unified.sort_values(
        by=["status_n","severity_n","confidence_n","value_at_risk","module_n","ts_n","entity"],
        ascending=[False, False, False, False, False, False, True],
    )

