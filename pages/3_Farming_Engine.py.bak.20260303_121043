def read_csv_safe(p: Path) -> pd.DataFrame:
    try:
        return pd.read_csv(p) if p.exists() else pd.DataFrame()
    except Exception:
        return pd.DataFrame()

def read_json_safe(p: Path):
    try:
        if p.exists():
            return json.loads(p.read_text())
        return {}
    except Exception:
        return {}

