    claims = pick(df, ["claims_deductions_cr","claims_cr","deductions_cr","returns_cr"])
    doh = pick(df, ["avg_doh","doh","days_on_hand"])
    fill = pick(df, ["fill_rate","service_level","otif"])
    corridor = pick(df, ["corridor_breach_count","price_corridor_breaches","corridor_breaches"])

    def num(x): 
        return pd.to_numeric(x, errors="coerce")

    k1,k2,k3,k4,k5,k6 = st.columns([0.17,0.17,0.17,0.17,0.17,0.15], gap="large")

    with k1:
        v = float(num(df[sellin]).sum()) if (sellin and not df.empty) else np.nan
